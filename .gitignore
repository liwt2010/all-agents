# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
env/
venv/

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data directories (runtime state, not source)
data/
!data/.gitkeep

# Node
node_modules/
web/dist/
web/.vite/

# Claude / IDE agent local config (machine-specific, not repo content)
.claude/
.aider*
.cursor/

# OS
.DS_Store
Thumbs.db

# Coverage
.coverage
.coverage.*
htmlcov/

# Generated artifacts (regeneratable from source)
openapi/openapi.json
openapi/openapi.yaml
sdks/

# Sub-projects that should live in their own repos —
# kept on disk for convenience but excluded from this repo.
projects/

# gRPC generated stubs — regenerated locally via
# `python -m agent_system.grpc.codegen` (200+ KB of auto-generated
# code; kept out of the repo to avoid bloat and merge noise).
src/agent_system/grpc/*_pb2.py
src/agent_system/grpc/*_pb2_grpc.py
