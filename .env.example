# all-agents — Production Environment
#
# Copy to .env and fill in. NEVER commit .env to git (it's in .gitignore).
# This file is the canonical reference for all environment variables.
# For full deployment guidance, see docs/PRODUCTION.md.

# ============================================================
# 1. REQUIRED — service will not start without these
# ============================================================

# JWT signing key (HS256, 32+ chars). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate every 90 days.
#
# Single-key mode (simple): set AUTH_SECRET
# Multi-key rotation (recommended for production):
#   AUTH_SECRETS="current_kid:current_secret,old_kid:old_secret"
# The first entry is the SIGNING key. All entries are valid for VERIFY.
# To rotate:
#   1. Generate a new secret, prepend it to AUTH_SECRETS (it's now current)
#   2. Keep the old secret in the list for 1+ token TTL (graceful rollover)
#   3. Remove the old secret once all tokens using it have expired
AUTH_SECRET=
# AUTH_SECRETS=v1:CHANGE_ME_long_random_string_32chars,v0:CHANGE_ME_old_random_string_32chars

# Environment: "development" or "production". Production enables
# strict checks (require_real_key() will fail loudly if no LLM key).
ENVIRONMENT=production

# LLM provider: "anthropic" (default, uses Anthropic SDK) or
# "openai" (uses OpenAI SDK, works with OpenAI-compatible proxies).
LLM_PROVIDER=anthropic

# ============================================================
# 2. REQUIRED for LLM calls
# ============================================================

# --- Option A: Anthropic (direct) ---
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Leave ANTHROPIC_BASE_URL unset unless using a proxy.

# --- Option B: OpenAI-compatible (DeepSeek, etc.) ---
# Get from your provider. The codebase supports any OpenAI-compatible
# endpoint (tested with new-api style proxies).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com

# --- Optional: override the default model ---
# Default: "deepseek-chat" (set in settings.yaml). Override here if
# you want to use a different model for all agents.
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MODEL=deepseek-v4-flash

# ============================================================
# 3. REQUIRED for PostgreSQL backend (production multi-node)
# ============================================================

# Skip this section if using SQLite (default for single-node prod).
POSTGRES_HOST=db.internal
POSTGRES_PORT=5432
POSTGRES_DB=all_agents
POSTGRES_USER=all_agents
POSTGRES_PASSWORD=

# For SQLite, the file path:
# AGENT_SQLITE_PATH=/data/graph.db

# For JSON (dev only):
# AGENT_JSON_DIR=/data/graph

# ============================================================
# 4. Storage backend selection
# ============================================================

# "json" (dev) | "sqlite" (single-node prod) | "postgres" (multi-node prod)
# Default: "json" if AGENT_STORAGE_BACKEND is unset.
# AGENT_STORAGE_BACKEND=sqlite

# ============================================================
# 5. Observability  (OPTIONAL — all have sensible defaults)
# ============================================================

# Master switch for metrics + tracing
AGENT_OBSERVABILITY_ENABLED=true

# Audit logger
AGENT_AUDIT_ENABLED=true
# 1.0 = log everything; 0.1 = log 10% of events
AGENT_AUDIT_SAMPLING_RATE=1.0
# 100 = flush batch every 100 entries; 5.0 = flush every 5 seconds
AGENT_AUDIT_BATCH_SIZE=100
AGENT_AUDIT_FLUSH_INTERVAL=5.0
AGENT_AUDIT_LOG_DIR=/data/audit
# Auto-purge audit files older than N days
AGENT_AUDIT_RETENTION_DAYS=90

# Backup scheduler (PR-13)
AGENT_BACKUP_ENABLED=true
AGENT_BACKUP_SCHEDULE_CRON=0 2 * * *
AGENT_BACKUP_DIR=/data/backup
AGENT_BACKUP_RETENTION_DAYS=7

# ============================================================
# 6. Rate limiting (PR-12)  (OPTIONAL — defaults are production-safe)
# ============================================================

AGENT_RATE_LIMIT_ENABLED=true
# Per-user per-minute limits by scope
AGENT_RATE_LIMIT_SCOPE_DEFAULT_USER=120
AGENT_RATE_LIMIT_SCOPE_DEFAULT_IP=240
AGENT_RATE_LIMIT_SCOPE_EXPENSIVE_USER=20
AGENT_RATE_LIMIT_SCOPE_EXPENSIVE_IP=60
AGENT_RATE_LIMIT_SCOPE_HEAVY_USER=10
AGENT_RATE_LIMIT_SCOPE_HEAVY_IP=30
AGENT_RATE_LIMIT_SCOPE_AUTH_USER=5
AGENT_RATE_LIMIT_SCOPE_AUTH_IP=30
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
# "open" = allow on error (default), "closed" = reject on error
AGENT_RATE_LIMIT_FAIL_MODE=open

# Legacy IP-only limit (used if AGENT_RATE_LIMIT_ENABLED=false)
RATE_LIMIT_PER_MINUTE=60

# ============================================================
# 7. Networking & resource limits  (OPTIONAL)
# ============================================================

# Max request body (bytes). Default 1MB.
MAX_REQUEST_BYTES=1048576

# File system roots agents can read. Comma-separated.
ALLOWED_FILE_ROOTS=data,tmp

# Async task worker pool size
MAX_TASK_WORKERS=10

# CORS — environment-aware (PR-16)
# In production: only https:// origins allowed, no wildcard, no localhost (unless explicit)
# In staging: staging.example.com + CORS_ALLOWED_ORIGINS + CORS_DEV_ORIGINS
# In dev: localhost:5173 + CORS_ALLOWED_ORIGINS + CORS_DEV_ORIGINS
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_DEV_ORIGINS=http://localhost:5173
# CORS_ALLOW_CREDENTIALS=true
# CORS_MAX_AGE=600

# ============================================================
# 8. Security middleware  (OPTIONAL — all on by default)
# ============================================================

# Set to 1 ONLY for local dev (disables all security middleware)
# DISABLE_SECURITY_MIDDLEWARE=0

# TLS / HTTPS enforcement (PR-16)
# TLS_REDIRECT_ENABLED — set to true ONLY when not behind a TLS-terminating LB
#   (CloudFront / nginx-ingress / ELB handle the redirect themselves)
# TLS_REDIRECT_ENABLED=false

# TLS_HSTS_ENABLED — adds Strict-Transport-Security header. On by default in production.
# TLS_HSTS_ENABLED=true
# TLS_HSTS_MAX_AGE=31536000
# TLS_HSTS_INCLUDE_SUBDOMAINS=true
# TLS_HSTS_PRELOAD=false  (only enable after submitting to hstspreload.org)

# TLS_SECURE_COOKIES — checks Set-Cookie headers for Secure flag
# TLS_SECURE_COOKIES=false
# TLS_SECURE_COOKIES_WARN_ONLY=true  (false = hard 500 on missing Secure)

# ============================================================
# 9. Misc  (OPTIONAL)
# ============================================================

# Postgres password for local docker-compose (auto-generated if unset)
# POSTGRES_PASSWORD=changeme123

# (deprecated) Public port — handled by reverse proxy in production
# PORT=8000
