# Agent System — Production Environment
# Copy this file to .env and edit for your deployment.

# === REQUIRED ===
# JWT signing secret (32+ characters). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=

# === REQUIRED for real LLM usage ===
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# === OPTIONAL ===
# Environment: development | production
ENVIRONMENT=production

# Postgres password (auto-generated by compose if not set)
POSTGRES_PASSWORD=changeme123

# === Limits ===
RATE_LIMIT_PER_MINUTE=60
ALLOWED_FILE_ROOTS=data,tmp
MAX_TASK_WORKERS=10
